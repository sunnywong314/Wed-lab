! inlist to evolve a 15 solar mass star

! For the sake of future readers of this file (yourself included),
! ONLY include the controls you are actually using.  DO NOT include
! all of the other controls that simply have their default values.

&star_job
  ! see star/defaults/star_job.defaults

  ! begin with a pre-main sequence model
    create_pre_main_sequence_model = .true.

    pre_ms_relax_num_steps = 50

    ! pre_ms_relax_to_start_radiative_core = .false.

    num_steps_to_relax_composition = 100
    relax_initial_to_xaccrete = .true.

  ! save a model at the end of the run
    save_model_when_terminate = .true.
    ! save_model_filename = '1.1Msun_ONeMg_S15.mod'
    save_model_filename = '1.1Msun_ONeNa.mod'

  ! nuclear net

    change_initial_net = .true.
    new_net_name = 'sagb_NeNa_MgAl.net'

  ! display on-screen plots
    pgstar_flag = .true.
    disable_pgstar_during_relax_flag = .false.

/ ! end of star_job namelist


&eos
  ! eos options
  ! see eos/defaults/eos.defaults

    use_OPAL_SCVH = .false.
    use_FreeEOS = .false.
    use_PC = .false.

    mass_fraction_limit_for_Skye = 1d-10 !0d0

/ ! end of eos namelist


&kap
  ! kap options
  ! see kap/defaults/kap.defaults
  use_Type2_opacities = .true.
  Zbase = 0.02

/ ! end of kap namelist


&controls
  ! see star/defaults/controls.defaults

  ! starting specifications
    initial_mass = 1.1d0 ! in Msun units
    initial_y = 1.0d0
    initial_z = 0.0d0

    accrete_given_mass_fractions = .true.

    ! only O, Ne
    ! num_accretion_species = 2
    ! accretion_species_id(1) = 'o16'
    ! accretion_species_xa(1) = 0.50d0
    ! accretion_species_id(2) = 'ne20'
    ! accretion_species_xa(2) = 0.5d0

    ! only O, Ne and Mg (Schwab, Quataert & Bildsten 2015)
    ! num_accretion_species = 3
    ! accretion_species_id(1) = 'o16'
    ! accretion_species_xa(1) = 0.50d0
    ! accretion_species_id(2) = 'ne20'
    ! accretion_species_xa(2) = 0.45d0
    ! accretion_species_id(3) = 'mg24'
    ! accretion_species_xa(3) = 0.05d0

    ! only O, Ne and Na
    num_accretion_species = 3
    accretion_species_id(1) = 'o16'
    accretion_species_xa(1) = 0.50d0
    accretion_species_id(2) = 'ne20'
    accretion_species_xa(2) = 0.45d0
    accretion_species_id(3) = 'na23'
    accretion_species_xa(3) = 0.05d0

    ! include Na23 and Mg25 (Schwab, Bildsten & Quataert 2017)
    ! num_accretion_species = 5
    ! accretion_species_id(1) = 'o16'
    ! accretion_species_xa(1) = 0.50d0
    ! accretion_species_id(2) = 'ne20'
    ! accretion_species_xa(2) = 0.39d0
    ! accretion_species_id(3) = 'na23'
    ! accretion_species_xa(3) = 0.05d0
    ! accretion_species_id(4) = 'mg24'
    ! accretion_species_xa(4) = 0.05d0
    ! accretion_species_id(5) = 'mg25'
    ! accretion_species_xa(5) = 0.01d0

  ! when to stop

    log_center_density_upper_limit = 7.5d0

  ! wind

  ! atmosphere

  ! rotation

  ! element diffusion

  ! mlt

  ! mixing

  ! timesteps

     ! we don't care about energy conservation, just the initial model
     limit_for_rel_error_in_energy_conservation = 1d-2
     hard_limit_for_rel_error_in_energy_conservation = 1d-1

  ! mesh

  ! solver
     ! options for energy conservation (see MESA V, Section 3)
     energy_eqn_option = 'eps_grav'
     use_gold_tolerances = .true.

     max_resid_jump_limit = 1d20

     scale_max_correction_for_negative_surf_lum = .true.

  ! output

  ! others

     max_abar_for_burning = -1
     ! eps_nuc_factor = 0d0
     ! dxdt_nuc_factor = 0d0

     ! pextra_factor = 4d0

     ! okay_to_reduce_gradT_excess = .true.
     ! gradT_excess_lambda1 = -1
     use_superad_reduction = .true.

/ ! end of controls namelist
