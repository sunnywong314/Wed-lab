! vary the model to load, nuclear net, rates, accretion rate, etc.
&star_job
  ! see star/defaults/star_job.defaults

  ! load previous model
    load_saved_model = .true.
    load_model_filename = '../make_one_wd/1.1Msun_ONeMg.mod'

  ! net

    change_initial_net = .true.
    new_net_name = 'nets_lab1/ONeMg.net'

  ! weak rates

    use_suzuki_weak_rates = .true.
    ! use_special_weak_rates = .true.
    ! special_weak_states_file = 'weak.states_full'
    ! special_weak_transitions_file = 'weak.transitions_full'

/ ! end of star_job namelist


&eos
  ! eos options
  ! see eos/defaults/eos.defaults

/ ! end of eos namelist


&kap
  ! kap options
  ! see kap/defaults/kap.defaults

/ ! end of kap namelist


&controls
  ! see star/defaults/controls.defaults

  ! accretion

    mass_change = 1d-6

    accrete_same_as_surface = .false.
    accrete_given_mass_fractions = .true.

    ! S15 abundances
    num_accretion_species = 3
    accretion_species_id(1) = 'o16'
    accretion_species_xa(1) = 0.5d0
    accretion_species_id(2) = 'ne20'
    accretion_species_xa(2) = 0.45d0
    accretion_species_id(3) = 'mg24'
    accretion_species_xa(3) = 0.05d0

  ! output

    log_directory = 'LOGS_ONeMg_1d-6'

/ ! end of controls namelist
